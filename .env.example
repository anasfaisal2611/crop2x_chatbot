# Example environment file - Copy to .env and fill with actual values

# ==================== FLASK CONFIGURATION ====================
FLASK_APP=run.py
FLASK_ENV=development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-12345

# ==================== DATABASE ====================
DATABASE_URL=sqlite:///crop2x.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# ==================== AI/ML SERVICES ====================
# OpenAI Configuration
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Google AI Configuration  
GOOGLE_GENERATIVEAI_KEY=AIzaSy_your-key-here
GOOGLE_AI_MODEL=gemini-pro

# ==================== TWILIO (WhatsApp) ====================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155552671
TWILIO_PHONE_SID=PPxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== EMAIL CONFIGURATION ====================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@crop2x.com

# ==================== POLICIES ====================
POLICIES_PATH=policies/dummy_policies.pdf
POLICY_UPDATE_INTERVAL=86400

# ==================== CORS CONFIGURATION ====================
CORS_ORIGINS=*,http://localhost:3000,https://crop2x.com

# ==================== SERVER CONFIGURATION ====================
HOST=0.0.0.0
PORT=5000
WORKERS=4

# ==================== ADMIN CONFIGURATION ====================
ADMIN_PHONE=+919876543210
ADMIN_EMAIL=admin@crop2x.com

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== SECURITY ====================
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
PASSWORD_MIN_LENGTH=8

# ==================== PRODUCTION SETTINGS ====================
# Set to production for deployment
ENVIRONMENT=development
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ==================== API KEYS ====================
API_KEY_SECRET=your-api-key-secret
API_RATE_LIMIT=100

# ==================== AWS (Optional) ====================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=crop2x-uploads

# ==================== REDIS (Optional) ====================
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL=3600

# ==================== WEBHOOK URLs ====================
WEBHOOK_URL=https://your-domain.com/api/whatsapp/webhook
WEBHOOK_SECRET=your-webhook-secret

# ==================== PRICING ====================
FARMER_PLAN_PRICE=500
FARMER_PLAN_CURRENCY=INR
COMMISSION_PERCENTAGE=25

# ==================== FEATURES ====================
ENABLE_WHATSAPP=True
ENABLE_EMAIL=False
ENABLE_SMS=False
ENABLE_PDF_UPLOAD=True

# ==================== DEBUG ====================
SHOW_STACK_TRACE=False
VERBOSE_LOGGING=False
